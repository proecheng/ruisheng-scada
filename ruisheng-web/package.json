{
  "name": "ruisheng-web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "tsx scripts/generate-build-info.ts",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "echarts": "^5.5.1",
    "pinia": "^2.2.4",
    "ulid": "^2.3.0",
    "vee-validate": "^4.13.2",
    "vue": "^3.4.38",
    "vue-i18n": "^9.14.1",
    "vue-konva": "^3.2.1",
    "vue-router": "^4.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^22.7.4",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitest/coverage-v8": "^2.1.2",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^9.12.0",
    "eslint-plugin-vue": "^9.28.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^2.1.2",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.1.6"
