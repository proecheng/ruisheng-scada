# ruisheng-api 环境变量模板
# 复制为 D:\ruisheng\config\ruisheng-api.env，填写所有 CHANGE_ME 后保存
# 文件权限建议：仅管理员可读（icacls ... /inheritance:r /grant Administrators:F）

# 勿改为 0.0.0.0：API 仅由本机 Nginx 访问，8000 端口不应对外暴露
API_LISTEN_HOST=127.0.0.1
API_LISTEN_PORT=8000

# PostgreSQL — ruisheng_api 角色（只读 + 业务写权限，无 BYPASSRLS）
API_DB_URL=postgresql+asyncpg://ruisheng_api:CHANGE_ME_API_PW@127.0.0.1:5432/ruisheng

# PostgreSQL — ruisheng_gw 角色（BYPASSRLS，用于登录时绕过 RLS 查 users 表）
API_GW_DB_URL=postgresql+asyncpg://ruisheng_gw:CHANGE_ME_GW_PW@127.0.0.1:5432/ruisheng

# Redis（Memurai）
API_REDIS_URL=redis://:CHANGE_ME_REDIS_PW@127.0.0.1:6379/0

# JWT 签名密钥：必须 >= 32 字符，建议用下方命令生成
# PowerShell: -join ((65..90)+(97..122)+(48..57) | Get-Random -Count 48 | %{[char]$_})
API_JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG

API_ENV=prod
