# ruisheng-gw 环境变量模板
# 复制为 D:\ruisheng\config\ruisheng-gw.env，填写所有 CHANGE_ME 后保存

GW_LISTEN_HOST=0.0.0.0
GW_LISTEN_PORT=5020

# PostgreSQL — ruisheng_gw 角色（BYPASSRLS）
GW_DATABASE_URL=postgresql+asyncpg://ruisheng_gw:CHANGE_ME_GW_PW@127.0.0.1:5432/ruisheng

# Redis（Memurai）
GW_REDIS_URL=redis://:CHANGE_ME_REDIS_PW@127.0.0.1:6379/0

# WAL 落盘目录（必须显式设置；若不设置将使用 Linux 默认路径导致启动失败）
GW_WAL_DIR=D:/ruisheng/gw/wal

# 串口设备（可选，无 RS485 设备时留空或删除）
# GW_SERIAL_PORTS=[{"port":"COM3","baud_rate":9600}]
