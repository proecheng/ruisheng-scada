# ============================================================
# ruisheng-scada 生产环境配置 — 复制为 .env.prod 并填写
# ============================================================
# 注意：.env.prod 已被 .gitignore 忽略，不要提交真实密码
# 生成随机密码（Linux/Mac）：openssl rand -base64 24
# 生成随机密码（Windows PowerShell）：
#   [System.Web.Security.Membership]::GeneratePassword(24,4)

# ---- PostgreSQL 超级用户（migrate 服务使用，用于 alembic 迁移）----
POSTGRES_USER=ruisheng_admin
POSTGRES_PASSWORD=CHANGE_ME_PG_SUPERUSER_PASSWORD

# ---- 应用 DB 角色密码（由 alembic 迁移 D3 写入数据库）----
RUISHENG_GW_PASSWORD=CHANGE_ME_GW_ROLE_PASSWORD
RUISHENG_API_PASSWORD=CHANGE_ME_API_ROLE_PASSWORD

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ---- JWT 签名密钥（最少 32 字符，随机字符串）----
JWT_SECRET=CHANGE_ME_JWT_SECRET_AT_LEAST_32_CHARS_RANDOM
